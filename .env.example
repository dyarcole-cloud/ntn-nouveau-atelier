# NTN Nouveau — environment variables.
# Copy to .env.local for local dev, or set these in the Netlify dashboard.
# Nothing here is required: with no env set, the app runs fully local
# (localStorage persistence) and the agents degrade gracefully.

# ── Persistence ──────────────────────────────────────────────────────────────
# "localStorage" (default) | "supabase". Supabase activates only when this is
# "supabase" AND the URL + anon key below are present.
VITE_PERSISTENCE_MODE=localStorage

# Supabase (anon / publishable key ONLY — never a service-role key). The project
# enforces RLS scoped to the workspace id.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_WORKSPACE_ID=00000000-0000-0000-0000-000000000001

# ── Agent proxy (server-side only — Netlify function, NOT exposed to browser) ──
# These are read by netlify/functions/anthropic.ts. Do NOT prefix with VITE_
# (that would bundle them into the client).
ANTHROPIC_API_KEY=
# Optional model override; defaults to claude-opus-4-8.
ANTHROPIC_MODEL=claude-opus-4-8
